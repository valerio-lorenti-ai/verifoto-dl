# Model files (stored on Drive)
# Ignore model checkpoints (too large for git)
*.pt
*.pth
*.ckpt
*.onnx
*.ts
checkpoints/

# But allow checkpoint metadata if needed
!checkpoints/README.md
!checkpoints/*/config.yaml

# Data (stored on Drive)
data/
dataset/
datasets/

# Jupyter
.ipynb_checkpoints
*.ipynb
!verifoto_dl.ipynb
!script/notebooks/verifoto_dl.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Outputs: Allow results but ignore heavy files
# Allow all files in outputs/runs/ by default
!outputs/runs/

# But ignore specific heavy files
outputs/runs/**/*.pt
outputs/runs/**/*.pth
outputs/runs/**/*.ckpt
outputs/runs/**/*.h5
outputs/runs/**/*.pkl
outputs/runs/**/*.npy
outputs/runs/**/*.npz

# Allow these important result files
!outputs/runs/**/metrics.json
!outputs/runs/**/predictions.csv
!outputs/runs/**/group_metrics_*.csv
!outputs/runs/**/top_false_*.csv
!outputs/runs/**/notes.md
!outputs/runs/**/CRITICAL_ANALYSIS.md
!outputs/runs/**/*.png
!outputs/runs/**/*.jpg
!outputs/runs/**/*.jpeg

# Agent context (AI assistant working files - NOT versioned)
.kiro/agent/
.kiro/notes/

# IMPORTANT: .kiro/agent/ should contain MAX 3 files:
# - status.md (main operational context)
# - decisions.md (technical reference)
# - README.md (structure guide)
# DO NOT create additional files in .kiro/agent/

# Temporary documentation files (NEVER commit these)
# Task-specific summaries, fixes, analyses
*_SUMMARY.md
*_COMPLETE.md
*_FIX.md
*_ANALYSIS*.md
*_UPDATE*.md
NEXT_STEPS*.md
QUICK_*.md
FIX_*.md
IMPLEMENTATION_*.md
NOTEBOOK_*.md
RISPOSTA_*.md
TRAIN_*_ANALYSIS.md
THRESHOLD_*.md
CALIBRATED_*.md
CONFIG_*_UPDATE*.md
DOMAIN_AWARE_*_SUMMARY.md

# Allow only essential documentation
!README.md
!CHECKPOINT_GUIDE.md
!CHECKPOINT_PIPELINE_GUIDE.md
!SPEED_OPTIMIZATION_GUIDE.md
